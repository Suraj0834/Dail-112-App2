<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/Widget.Dial112.Card"
    android:layout_width="280dp"
    android:layout_height="wrap_content"
    android:layout_marginEnd="@dimen/spacing_md"
    app:cardBackgroundColor="@color/emergency_red_dark"
    app:strokeColor="@color/emergency_red"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_lg">

        <!-- Header Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Pulse Icon -->
            <ImageView
                android:layout_width="@dimen/icon_sm"
                android:layout_height="@dimen/icon_sm"
                android:src="@drawable/ic_pulse"
                android:contentDescription="@null"
                app:tint="@color/emergency_red_light" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/spacing_sm"
                android:text="LIVE"
                android:textAppearance="@style/TextAppearance.Dial112.LabelSmall"
                android:textColor="@color/emergency_red_light"
                android:letterSpacing="0.1" />

            <!-- Time -->
            <TextView
                android:id="@+id/tvTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2 min ago"
                android:textAppearance="@style/TextAppearance.Dial112.LabelSmall"
                android:textColor="@color/text_on_primary"
                android:alpha="0.7" />
        </LinearLayout>

        <!-- User Info -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/ivUser"
                android:layout_width="@dimen/avatar_md"
                android:layout_height="@dimen/avatar_md"
                android:src="@drawable/ic_person"
                app:civ_border_width="1dp"
                app:civ_border_color="@color/text_on_primary" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/spacing_md"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvUserName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Priya Sharma"
                    android:textAppearance="@style/TextAppearance.Dial112.TitleMedium"
                    android:textColor="@color/text_on_primary" />

                <TextView
                    android:id="@+id/tvUserPhone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xxs"
                    android:text="+91 98765 43210"
                    android:textAppearance="@style/TextAppearance.Dial112.BodyMedium"
                    android:textColor="@color/text_on_primary"
                    android:alpha="0.8" />
            </LinearLayout>
        </LinearLayout>

        <!-- Location -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="@dimen/icon_sm"
                android:layout_height="@dimen/icon_sm"
                android:src="@drawable/ic_location"
                android:contentDescription="@null"
                app:tint="@color/text_on_primary"
                android:alpha="0.8" />

            <TextView
                android:id="@+id/tvLocation"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/spacing_sm"
                android:text="MG Road, Bengaluru"
                android:textAppearance="@style/TextAppearance.Dial112.BodyMedium"
                android:textColor="@color/text_on_primary"
                android:alpha="0.8"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>

        <!-- Distance & ETA -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Distance"
                    android:textAppearance="@style/TextAppearance.Dial112.LabelSmall"
                    android:textColor="@color/text_on_primary"
                    android:alpha="0.6" />

                <TextView
                    android:id="@+id/tvDistance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2.5 km"
                    android:textAppearance="@style/TextAppearance.Dial112.TitleMedium"
                    android:textColor="@color/text_on_primary" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ETA"
                    android:textAppearance="@style/TextAppearance.Dial112.LabelSmall"
                    android:textColor="@color/text_on_primary"
                    android:alpha="0.6" />

                <TextView
                    android:id="@+id/tvETA"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="5 min"
                    android:textAppearance="@style/TextAppearance.Dial112.TitleMedium"
                    android:textColor="@color/text_on_primary" />
            </LinearLayout>
        </LinearLayout>

        <!-- Respond Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRespond"
            style="@style/Widget.Dial112.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:text="@string/police_respond"
            app:backgroundTint="@color/text_on_primary"
            android:textColor="@color/emergency_red_dark" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
