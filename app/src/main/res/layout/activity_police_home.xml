<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1B2A">

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:paddingBottom="80dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- HEADER WITH GRADIENT -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_police_header_gradient"
                android:orientation="vertical"
                android:padding="20dp"
                android:paddingBottom="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DUTY DASHBOARD"
                    android:textColor="#BFDBFE"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.1"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="8dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvGreeting"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Inspector Ravi Kumar"
                            android:textColor="@android:color/white"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-medium"/>

                        <TextView
                            android:id="@+id/tvBadgeId"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Badge ID: POL-001"
                            android:textColor="#BFDBFE"
                            android:textSize="12sp"
                            android:layout_marginTop="2dp"/>

                    </LinearLayout>

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="ON DUTY"
                        android:textColor="@android:color/white"
                        android:textSize="10sp"
                        app:chipBackgroundColor="#10B981"
                        app:chipStrokeWidth="0dp"
                        app:chipMinHeight="32dp"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvStation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📍 Connaught Place PS"
                    android:textColor="#BFDBFE"
                    android:textSize="13sp"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>

            <!-- CONTENT -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="20dp">

                <!-- LIVE SOS ALERTS -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="LIVE SOS ALERTS"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.05"/>

                    <TextView
                        android:id="@+id/tvAlertCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2 Active"
                        android:textColor="#EF4444"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-medium"/>
                </LinearLayout>

                <!-- SOS ALERTS RECYCLER -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvSOSAlerts"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:nestedScrollingEnabled="false"/>

                <TextView
                    android:id="@+id/tvNoAlerts"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No active SOS alerts"
                    android:textColor="#64748B"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:padding="32dp"
                    android:visibility="gone"/>

                <!-- QUICK TOOLS -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="QUICK TOOLS"
                    android:textColor="#94A3B8"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.05"
                    android:layout_marginTop="28dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginTop="16dp">

                    <!-- Criminal Search -->
                    <LinearLayout
                        android:id="@+id/btnCriminalSearch"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:clickable="true"
                        android:focusable="true"
                        android:padding="8dp">

                        <FrameLayout
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            android:background="@drawable/bg_circle_blue">

                            <ImageView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_search"
                                app:tint="@android:color/white"/>
                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Criminal\nSearch"
                            android:textColor="#FFFFFF"
                            android:textSize="11sp"
                            android:gravity="center"
                            android:layout_marginTop="8dp"/>
                    </LinearLayout>

                    <!-- Criminal AI -->
                    <LinearLayout
                        android:id="@+id/btnCriminalAI"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:clickable="true"
                        android:focusable="true"
                        android:padding="8dp">

                        <FrameLayout
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            android:background="@drawable/bg_circle_purple">

                            <ImageView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_face_scan"
                                app:tint="@android:color/white"/>
                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Criminal\nAI"
                            android:textColor="#FFFFFF"
                            android:textSize="11sp"
                            android:gravity="center"
                            android:layout_marginTop="8dp"/>
                    </LinearLayout>

                    <!-- PCR Van -->
                    <LinearLayout
                        android:id="@+id/btnPcrVan"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:clickable="true"
                        android:focusable="true"
                        android:padding="8dp">

                        <FrameLayout
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            android:background="@drawable/bg_circle_green">

                            <ImageView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_car"
                                app:tint="@android:color/white"/>
                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="PCR Van"
                            android:textColor="#FFFFFF"
                            android:textSize="11sp"
                            android:gravity="center"
                            android:layout_marginTop="8dp"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- MY ASSIGNED CASES -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="28dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="MY ASSIGNED CASES"
                        android:textColor="#94A3B8"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.05"/>

                    <TextView
                        android:id="@+id/btnViewAllCases"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="View All →"
                        android:textColor="#3B82F6"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-medium"
                        android:clickable="true"
                        android:focusable="true"
                        android:padding="4dp"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvNoCases"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No assigned cases"
                    android:textColor="#64748B"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:padding="32dp"
                    android:visibility="gone"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvAssignedCases"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:nestedScrollingEnabled="false"/>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Navigation Container -->
    <FrameLayout
        android:id="@+id/bottomNavContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom">

        <!-- Bottom Navigation View -->
        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottomNav"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:background="#1A1F2E"
            app:itemIconTint="@color/bottom_nav_color"
            app:itemTextColor="@color/bottom_nav_color"
            app:itemIconSize="24dp"
            app:labelVisibilityMode="labeled"
            app:itemTextAppearanceActive="@style/BottomNavTextActive"
            app:itemTextAppearanceInactive="@style/BottomNavTextInactive"
            app:menu="@menu/bottom_nav_police"
            app:elevation="8dp" />

    </FrameLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
