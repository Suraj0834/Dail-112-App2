<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    tools:context=".ui.CitizenHomeActivity">

    <!-- Main Content -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:paddingBottom="90dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- HEADER WITH GRADIENT -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_citizen_header_gradient"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="24dp"
                android:paddingBottom="32dp">

                <!-- Top Bar -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/good_morning"
                            android:textColor="#DBEAFE"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif"/>

                        <TextView
                            android:id="@+id/tvGreeting"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Priya"
                            android:textColor="@android:color/white"
                            android:textSize="26sp"
                            android:textStyle="bold"
                            android:layout_marginTop="2dp"
                            android:fontFamily="sans-serif-medium"/>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="6dp">

                            <ImageView
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:src="@drawable/ic_location"
                                app:tint="#93C5FD" />

                            <TextView
                                android:id="@+id/tvLocation"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="New Delhi, India"
                                android:textColor="#BFDBFE"
                                android:textSize="12sp"
                                android:layout_marginStart="4dp"/>

                        </LinearLayout>

                    </LinearLayout>

                    <!-- Notification Bell -->
                    <FrameLayout
                        android:id="@+id/btnNotifications"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layout_marginEnd="8dp"
                        android:background="?attr/selectableItemBackgroundBorderless">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_notifications"
                            app:tint="@android:color/white"/>

                        <!-- Notification Badge -->
                        <TextView
                            android:id="@+id/tvNotificationBadge"
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_gravity="top|end"
                            android:layout_marginTop="6dp"
                            android:layout_marginEnd="6dp"
                            android:background="@drawable/bg_notification_badge"
                            android:gravity="center"
                            android:text="3"
                            android:textColor="@android:color/white"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:visibility="visible"/>

                    </FrameLayout>

                    <!-- Profile -->
                    <de.hdodenhof.circleimageview.CircleImageView
                        android:id="@+id/btnProfile"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:src="@drawable/ic_person"
                        app:civ_border_width="2dp"
                        app:civ_border_color="@android:color/white"
                        android:clickable="true"
                        android:focusable="true"/>

                </LinearLayout>

            </LinearLayout>

            <!-- Content Container -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp">

                <!-- SOS EMERGENCY CARD -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardSOS"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:layout_marginTop="-24dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="8dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_sos_card_gradient"
                        android:padding="24dp">

                        <!-- Emergency Icon -->
                        <ImageView
                            android:id="@+id/ivEmergencyIcon"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:layout_alignParentTop="true"
                            android:layout_alignParentStart="true"
                            android:src="@drawable/ic_emergency"
                            android:alpha="0.3"
                            app:tint="@android:color/white" />

                        <!-- SOS Button Circle -->
                        <FrameLayout
                            android:layout_width="120dp"
                            android:layout_height="120dp"
                            android:layout_centerInParent="true"
                            android:background="@drawable/bg_sos_pulse">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:text="@string/nav_sos"
                                android:textColor="#EF4444"
                                android:textSize="28sp"
                                android:textStyle="bold"
                                android:fontFamily="sans-serif-black"/>

                        </FrameLayout>

                        <!-- Instruction Text -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_alignParentBottom="true"
                            android:layout_centerHorizontal="true">

                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:src="@drawable/ic_touch"
                                app:tint="@android:color/white"
                                android:alpha="0.9" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/sos_hold_instruction"
                                android:textColor="@android:color/white"
                                android:textSize="13sp"
                                android:layout_marginStart="6dp"
                                android:alpha="0.9"/>

                        </LinearLayout>

                    </RelativeLayout>

                </androidx.cardview.widget.CardView>

                <!-- QUICK ACTIONS -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/quick_actions"
                    android:textColor="#9CA3AF"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.1"
                    android:textAllCaps="true"
                    android:layout_marginTop="28dp"
                    android:layout_marginBottom="16dp"/>

                <!-- Quick Actions Grid -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <!-- File FIR -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/btnFileFir"
                        android:layout_width="0dp"
                        android:layout_height="100dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:layout_marginBottom="12dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="2dp"
                        android:backgroundTint="#1E293B"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="16dp">

                            <FrameLayout
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:background="@drawable/bg_icon_circle_blue">

                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_document"
                                    app:tint="@android:color/white"/>

                            </FrameLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/file_fir"
                                android:textColor="@android:color/white"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:layout_marginTop="8dp"
                                android:fontFamily="sans-serif-medium"/>

                        </LinearLayout>

                    </androidx.cardview.widget.CardView>

                    <!-- My Cases -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/btnMyCases"
                        android:layout_width="0dp"
                        android:layout_height="100dp"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:layout_marginBottom="12dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="2dp"
                        android:backgroundTint="#1E293B"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="16dp">

                            <FrameLayout
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:background="@drawable/bg_icon_circle_green">

                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_folder"
                                    app:tint="@android:color/white"/>

                            </FrameLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/my_cases"
                                android:textColor="@android:color/white"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:layout_marginTop="8dp"
                                android:fontFamily="sans-serif-medium"/>

                        </LinearLayout>

                    </androidx.cardview.widget.CardView>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <!-- Crime Map -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/btnCrimeMap"
                        android:layout_width="0dp"
                        android:layout_height="100dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:layout_marginBottom="12dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="2dp"
                        android:backgroundTint="#1E293B"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="16dp">

                            <FrameLayout
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:background="@drawable/bg_icon_circle_purple">

                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_location"
                                    app:tint="@android:color/white"/>

                            </FrameLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/crime_map"
                                android:textColor="@android:color/white"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:layout_marginTop="8dp"
                                android:fontFamily="sans-serif-medium"/>

                        </LinearLayout>

                    </androidx.cardview.widget.CardView>

                    <!-- AI Chat -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/btnAiChat"
                        android:layout_width="0dp"
                        android:layout_height="100dp"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:layout_marginBottom="12dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="2dp"
                        android:backgroundTint="#1E293B"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="16dp">

                            <FrameLayout
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:background="@drawable/bg_icon_circle_orange">

                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_bot"
                                    app:tint="@android:color/white"/>

                            </FrameLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/ai_chat"
                                android:textColor="@android:color/white"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:layout_marginTop="8dp"
                                android:fontFamily="sans-serif-medium"/>

                        </LinearLayout>

                    </androidx.cardview.widget.CardView>

                </LinearLayout>

                <!-- RECENT CASES -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="@string/my_recent_cases"
                        android:textColor="#9CA3AF"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.1"
                        android:textAllCaps="true"
                        android:layout_weight="1"/>

                    <TextView
                        android:id="@+id/btnViewAll"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/view_all"
                        android:textColor="#3B82F6"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        android:clickable="true"
                        android:focusable="true"
                        android:padding="8dp"
                        android:background="?attr/selectableItemBackgroundBorderless"/>

                </LinearLayout>

                <!-- Empty State -->
                <LinearLayout
                    android:id="@+id/layoutEmptyState"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="40dp"
                    android:visibility="gone">

                    <ImageView
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:src="@drawable/ic_empty_cases"
                        android:alpha="0.3"
                        app:tint="#60A5FA" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="@string/no_recent_cases"
                        android:textColor="#6B7280"
                        android:textSize="14sp"
                        android:gravity="center" />

                </LinearLayout>

                <!-- Recent Cases List -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvRecentCases"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:clipToPadding="false"/>

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- Modern Bottom Navigation -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        app:cardCornerRadius="0dp"
        app:cardElevation="12dp"
        android:backgroundTint="#0F1623">

        <FrameLayout
            android:id="@+id/bottomNavContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_bottom_nav_citizen">

            <!-- Bottom Navigation View -->
            <com.google.android.material.bottomnavigation.BottomNavigationView
                android:id="@+id/bottomNav"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:background="@android:color/transparent"
                app:itemIconTint="@color/bottom_nav_color"
                app:itemTextColor="@color/bottom_nav_color"
                app:itemIconSize="24dp"
                app:labelVisibilityMode="labeled"
                app:itemTextAppearanceActive="@style/BottomNavTextActive"
                app:itemTextAppearanceInactive="@style/BottomNavTextInactive"
                app:menu="@menu/bottom_nav_citizen"
                app:elevation="0dp" />

            <!-- Elevated SOS FAB -->
            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabSOS"
                android:layout_width="68dp"
                android:layout_height="68dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="24dp"
                android:src="@drawable/ic_sos"
                android:contentDescription="@string/sos"
                app:backgroundTint="#EF4444"
                app:tint="@android:color/white"
                app:elevation="16dp"
                app:fabSize="normal"
                app:borderWidth="0dp"
                app:rippleColor="#DC2626"
                app:maxImageSize="32dp" />

        </FrameLayout>

    </com.google.android.material.card.MaterialCardView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
