<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1B2A"
    tools:context=".ui.CaseHistoryActivity">

    <!-- Hero Header with Dark Gradient -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_history_header_gradient"
        android:elevation="4dp"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="@dimen/padding_16"
            android:paddingTop="12dp"
            android:paddingBottom="24dp">

            <!-- Back Button -->
            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/back"
                android:src="@drawable/ic_arrow_back"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="@color/text_white" />

            <!-- Title with Icon -->
            <ImageView
                android:id="@+id/iv_history_icon"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_history"
                android:contentDescription="@string/case_history"
                app:tint="#3B82F6"
                android:layout_marginStart="12dp"
                app:layout_constraintStart_toEndOf="@id/btn_back"
                app:layout_constraintTop_toTopOf="@id/btn_back"
                app:layout_constraintBottom_toBottomOf="@id/btn_back" />

            <TextView
                android:id="@+id/tv_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/case_history"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/text_white"
                android:fontFamily="sans-serif-medium"
                android:layout_marginStart="12dp"
                app:layout_constraintStart_toEndOf="@id/iv_history_icon"
                app:layout_constraintEnd_toStartOf="@id/btn_sort"
                app:layout_constraintTop_toTopOf="@id/btn_back"
                app:layout_constraintBottom_toBottomOf="@id/btn_back" />

            <!-- Sort Button -->
            <ImageButton
                android:id="@+id/btn_sort"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/sort_by"
                android:src="@drawable/ic_sort"
                android:layout_marginEnd="8dp"
                app:layout_constraintEnd_toStartOf="@id/btn_advanced_filter"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="@color/text_white" />

            <!-- Filter Button -->
            <ImageButton
                android:id="@+id/btn_advanced_filter"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/filter_by"
                android:src="@drawable/ic_filter"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="@color/text_white" />

            <!-- Stats Cards Row -->
            <LinearLayout
                android:id="@+id/stats_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="20dp"
                app:layout_constraintTop_toBottomOf="@id/btn_back">

                <!-- Total Cases Stat -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_stat_card_glass"
                    android:padding="16dp"
                    android:layout_marginEnd="8dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_folder"
                        android:contentDescription="@string/total_cases"
                        app:tint="#3B82F6" />

                    <TextView
                        android:id="@+id/tv_stat_total"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="156"
                        android:textSize="32sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_white"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginTop="8dp"
                        tools:text="156" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/total_cases"
                        android:textSize="11sp"
                        android:textColor="@color/text_white"
                        android:alpha="0.7"
                        android:layout_marginTop="4dp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="8dp">

                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:src="@drawable/ic_trending_up"
                            android:contentDescription="@string/trending"
                            app:tint="#10B981" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="+12%"
                            android:textSize="11sp"
                            android:textColor="#10B981"
                            android:layout_marginStart="4dp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Active Cases Stat -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_stat_card_glass"
                    android:padding="16dp"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_alert"
                        android:contentDescription="@string/active_cases_count"
                        app:tint="#F97316" />

                    <TextView
                        android:id="@+id/tv_stat_active"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="14"
                        android:textSize="32sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_white"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginTop="8dp"
                        tools:text="14" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/active_cases_count"
                        android:textSize="11sp"
                        android:textColor="@color/text_white"
                        android:alpha="0.7"
                        android:layout_marginTop="4dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Urgent"
                        android:textSize="11sp"
                        android:textColor="#F97316"
                        android:layout_marginTop="8dp" />
                </LinearLayout>

                <!-- Resolved Cases Stat -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/bg_stat_card_glass"
                    android:padding="16dp"
                    android:layout_marginStart="8dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_check_circle"
                        android:contentDescription="@string/resolved_30d"
                        app:tint="#10B981" />

                    <TextView
                        android:id="@+id/tv_stat_resolved"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="42"
                        android:textSize="32sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_white"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginTop="8dp"
                        tools:text="42" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/resolved_30d"
                        android:textSize="11sp"
                        android:textColor="@color/text_white"
                        android:alpha="0.7"
                        android:layout_marginTop="4dp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="8dp">

                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:src="@drawable/ic_trending_up"
                            android:contentDescription="@string/trending"
                            app:tint="#10B981" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="+8%"
                            android:textSize="11sp"
                            android:textColor="#10B981"
                            android:layout_marginStart="4dp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Main Content with Pull-to-Refresh -->
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipe_refresh"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="com.google.android.material.appbar.AppBarLayout$ScrollingViewBehavior">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/padding_16">

                <!-- Enhanced Search Bar -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="@drawable/bg_search_enhanced"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp"
                    android:layout_marginBottom="20dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_search"
                        android:contentDescription="@string/search"
                        app:tint="#64748B" />

                    <EditText
                        android:id="@+id/et_search_cases"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:background="@android:color/transparent"
                        android:hint="@string/search_cases"
                        android:inputType="text"
                        android:textColorHint="#64748B"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:fontFamily="sans-serif" />

                    <ImageView
                        android:id="@+id/iv_clear_search"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_close"
                        android:contentDescription="Clear"
                        android:visibility="gone"
                        app:tint="#64748B" />
                </LinearLayout>

                <!-- Filter Chips -->
                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:clipToPadding="false"
                    android:layout_marginBottom="20dp">

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chip_group_filters"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:singleSelection="true"
                        app:selectionRequired="true">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_all"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:text="@string/all"
                            android:textColor="@color/chip_filter_text_color"
                            android:checked="true"
                            app:chipBackgroundColor="@color/chip_filter_background"
                            app:chipStrokeWidth="0dp" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_pending"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:text="@string/pending"
                            android:textColor="@color/chip_filter_text_color"
                            app:chipBackgroundColor="@color/chip_filter_background"
                            app:chipStrokeColor="#334155"
                            app:chipStrokeWidth="1dp" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_active"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:text="Active"
                            android:textColor="@color/chip_filter_text_color"
                            app:chipBackgroundColor="@color/chip_filter_background"
                            app:chipStrokeColor="#334155"
                            app:chipStrokeWidth="1dp" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_resolved"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:text="@string/resolved"
                            android:textColor="@color/chip_filter_text_color"
                            app:chipBackgroundColor="@color/chip_filter_background"
                            app:chipStrokeColor="#334155"
                            app:chipStrokeWidth="1dp" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_closed"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:text="Closed"
                            android:textColor="@color/chip_filter_text_color"
                            app:chipBackgroundColor="@color/chip_filter_background"
                            app:chipStrokeColor="#334155"
                            app:chipStrokeWidth="1dp" />
                    </com.google.android.material.chip.ChipGroup>
                </HorizontalScrollView>

                <!-- Results Count -->
                <TextView
                    android:id="@+id/tv_results_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Showing 156 cases"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="16dp"
                    tools:text="Showing 156 cases" />

                <!-- Cases RecyclerView -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_cases"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clipToPadding="false"
                    android:scrollbars="vertical"
                    tools:listitem="@layout/item_case"
                    tools:itemCount="5" />

                <!-- Empty State -->
                <LinearLayout
                    android:id="@+id/empty_state"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="48dp"
                    android:visibility="gone"
                    tools:visibility="visible">

                    <ImageView
                        android:layout_width="120dp"
                        android:layout_height="120dp"
                        android:src="@drawable/ic_empty_cases"
                        android:contentDescription="@string/no_cases_found"
                        android:alpha="0.3" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/no_cases_found"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginTop="16dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Try adjusting your filters or search terms"
                        android:textSize="14sp"
                        android:textColor="@color/text_secondary"
                        android:textAlignment="center"
                        android:layout_marginTop="8dp" />
                </LinearLayout>

            </LinearLayout>

        </androidx.core.widget.NestedScrollView>

    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>