<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Typography Styles -->
    <style name="TextAppearance.Dial112.DisplayLarge" parent="TextAppearance.Material3.DisplayLarge">
        <item name="android:textSize">@dimen/text_display_large</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>
    
    <style name="TextAppearance.Dial112.HeadlineLarge" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:textSize">@dimen/text_headline_large</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>
    
    <style name="TextAppearance.Dial112.HeadlineMedium" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textSize">@dimen/text_headline_medium</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>
    
    <style name="TextAppearance.Dial112.TitleLarge" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textSize">@dimen/text_title_large</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>
    
    <style name="TextAppearance.Dial112.TitleMedium" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textSize">@dimen/text_title_medium</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>
    
    <style name="TextAppearance.Dial112.BodyLarge" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textSize">@dimen/text_body_large</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>
    
    <style name="TextAppearance.Dial112.BodyMedium" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textSize">@dimen/text_body_medium</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>
    
    <style name="TextAppearance.Dial112.LabelLarge" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:textSize">@dimen/text_label_large</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>
    
    <style name="TextAppearance.Dial112.LabelSmall" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textSize">@dimen/text_label_small</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.1</item>
    </style>
    
    <!-- Button Styles -->
    <style name="Widget.Dial112.Button.Primary" parent="Widget.Material3.Button">
        <item name="android:layout_height">@dimen/button_height</item>
        <item name="android:paddingStart">@dimen/button_padding_horizontal</item>
        <item name="android:paddingEnd">@dimen/button_padding_horizontal</item>
        <item name="backgroundTint">@color/primary</item>
        <item name="android:textColor">@color/text_on_primary</item>
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">@dimen/button_radius</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
    
    <style name="Widget.Dial112.Button.Secondary" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:layout_height">@dimen/button_height</item>
        <item name="android:paddingStart">@dimen/button_padding_horizontal</item>
        <item name="android:paddingEnd">@dimen/button_padding_horizontal</item>
        <item name="strokeColor">@color/border</item>
        <item name="strokeWidth">@dimen/input_stroke_width</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">@dimen/button_radius</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>
    
    <style name="Widget.Dial112.Button.Emergency" parent="Widget.Material3.Button">
        <item name="android:layout_height">@dimen/button_height_large</item>
        <item name="android:paddingStart">@dimen/button_padding_horizontal</item>
        <item name="android:paddingEnd">@dimen/button_padding_horizontal</item>
        <item name="backgroundTint">@color/emergency_red</item>
        <item name="android:textColor">@color/text_on_primary</item>
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">@dimen/button_radius</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
    
    <style name="Widget.Dial112.Button.Text" parent="Widget.Material3.Button.TextButton">
        <item name="android:textColor">@color/accent</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>
    
    <!-- Card Styles -->
    <style name="Widget.Dial112.Card" parent="Widget.Material3.CardView.Filled">
        <item name="cardBackgroundColor">@color/surface_card</item>
        <item name="cardCornerRadius">@dimen/card_radius</item>
        <item name="cardElevation">0dp</item>
        <item name="contentPadding">@dimen/card_padding</item>
    </style>
    
    <style name="Widget.Dial112.Card.Elevated" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/surface_card</item>
        <item name="cardCornerRadius">@dimen/card_radius</item>
        <item name="cardElevation">@dimen/card_elevation</item>
        <item name="contentPadding">@dimen/card_padding</item>
    </style>
    
    <style name="Widget.Dial112.Card.Outlined" parent="Widget.Material3.CardView.Outlined">
        <item name="cardBackgroundColor">@color/surface_card</item>
        <item name="cardCornerRadius">@dimen/card_radius</item>
        <item name="strokeColor">@color/border</item>
        <item name="strokeWidth">@dimen/input_stroke_width</item>
        <item name="contentPadding">@dimen/card_padding</item>
    </style>
    
    <!-- Input Styles -->
    <style name="Widget.Dial112.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/surface_elevated</item>
        <item name="boxCornerRadiusTopStart">@dimen/input_radius</item>
        <item name="boxCornerRadiusTopEnd">@dimen/input_radius</item>
        <item name="boxCornerRadiusBottomStart">@dimen/input_radius</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/input_radius</item>
        <item name="boxStrokeColor">@color/border</item>
        <item name="boxStrokeWidth">@dimen/input_stroke_width</item>
        <item name="hintTextColor">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_secondary</item>
    </style>
    
    <!-- Bottom Navigation -->
    <style name="Widget.Dial112.BottomNavigation" parent="Widget.Material3.BottomNavigationView">
        <item name="android:background">@color/surface_card</item>
        <item name="itemIconTint">@color/bottom_nav_icon_color</item>
        <item name="itemTextColor">@color/bottom_nav_text_color</item>
        <item name="itemActiveIndicatorStyle">@style/Widget.Dial112.BottomNavigation.ActiveIndicator</item>
        <item name="elevation">@dimen/bottom_nav_elevation</item>
    </style>
    
    <style name="Widget.Dial112.BottomNavigation.ActiveIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/primary</item>
    </style>

    <style name="BottomNavTextActive">
        <item name="android:textSize">11sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="BottomNavTextInactive">
        <item name="android:textSize">11sp</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>
    
    <!-- Chip Styles -->
    <style name="Widget.Dial112.Chip.Status" parent="Widget.Material3.Chip.Assist">
        <item name="chipBackgroundColor">@color/surface_elevated</item>
        <item name="chipCornerRadius">@dimen/radius_full</item>
        <item name="chipStrokeWidth">0dp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">@dimen/text_label_small</item>
    </style>
    
    <style name="Widget.Dial112.Chip.Status.Active" parent="Widget.Dial112.Chip.Status">
        <item name="chipBackgroundColor">@color/success_green</item>
        <item name="android:textColor">@color/text_on_primary</item>
    </style>
    
    <style name="Widget.Dial112.Chip.Status.Urgent" parent="Widget.Dial112.Chip.Status">
        <item name="chipBackgroundColor">@color/emergency_red</item>
        <item name="android:textColor">@color/text_on_primary</item>
    </style>
    
    <style name="Widget.Dial112.Chip.Status.Pending" parent="Widget.Dial112.Chip.Status">
        <item name="chipBackgroundColor">@color/warning_amber</item>
        <item name="android:textColor">@color/text_on_primary</item>
    </style>

    <!-- Bottom Navigation Active Indicator -->
    <style name="BottomNavActiveIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">#334155</item>
        <item name="android:height">32dp</item>
        <item name="android:width">64dp</item>
    </style>
</resources>
